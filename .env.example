# ContentHub 环境变量配置
# 复制此文件为 .env 并填入实际值

# ============ AI 服务（可选）============
# AI API Key，用于调用大模型生成文案
# 不填写则使用内置模拟文案生成器
AI_API_KEY=

# ============ Redis 配置（可选）============
# Redis 用于任务队列，不填写则使用内存队列
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ============ 服务器配置============
# API 服务端口
PORT=8001

# ============ 上传配置============
# 最大文件大小（字节）
MAX_FILE_SIZE=52428800

# 上传目录
UPLOAD_DIR=E:/openclaw/data/ContentHub/uploads
